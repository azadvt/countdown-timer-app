  "jest": {
    "transform": {},
        "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=16.13.0"
  },
  "dependencies": {
    "@shopify/shopify-app-express": "^5.0.8",
    "@shopify/shopify-app-session-storage-sqlite": "^4.0.8",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "mongoose": "^9.3.3",
    "serve-static": "^1.14.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^2.0.15",
    "prettier": "^2.6.2",
    "pretty-quick": "^3.1.3",
    "supertest": "^7.2.2"
  }
